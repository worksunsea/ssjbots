# Copy to .env and fill in values before `docker compose up`

# Shared secret between Vercel /api and this service (protects POST /send)
SERVICE_SECRET=

# Where to forward incoming WhatsApp messages
VERCEL_WEBHOOK_URL=https://ssjbots.vercel.app/api/webhook
VERCEL_WEBHOOK_SECRET=d6721171812ae071673b828f3054b69a

# Logical id tagged onto every forwarded message (matches funnels.wbiztool_client
# so the bot knows which funnel this WhatsApp number belongs to).
# Use a distinct id per Baileys instance if you run multiple containers.
WA_CLIENT_ID=ssj-test

# Baileys log verbosity: trace, debug, info, warn, error
BAILEYS_LOG=warn
